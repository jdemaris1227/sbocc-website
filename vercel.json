{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "redirects": [
    { "source": "/candidate", "destination": "https://electpsoras.com", "permanent": false },
    { "source": "/voter-guide", "destination": "https://carrollcountyvotes2026.com", "permanent": false },
    { "source": "/justice", "destination": "https://carrollcountyjustice.org", "permanent": false }
  ],
  "functions": {
    "api/chat.js": { "memory": 256, "maxDuration": 30 },
    "api/signup.js": { "memory": 256, "maxDuration": 30 }
  }
}
